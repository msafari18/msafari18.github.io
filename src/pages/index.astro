---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import PublicationList from "../components/PublicationList.astro";
import AwardsSection from "../components/AwardsSection.astro";
import ServiceSection from "../components/ServiceSection.astro";
import { readFileSync } from "fs";
import { parse } from "yaml";

const publications = parse(
  readFileSync("src/data/publications.yml", "utf-8"),
);
const preprints = parse(readFileSync("src/data/preprints.yml", "utf-8"));
const awards = parse(readFileSync("src/data/awards.yml", "utf-8"));
const services = parse(readFileSync("src/data/service.yml", "utf-8"));
---

<BaseLayout>
  <div class="mx-auto max-w-5xl space-y-16 px-6 py-16">
    <Hero />
    <PublicationList
      title="Publications"
      id="publications"
      publications={publications}
    />
    <AwardsSection awards={awards} />
    <PublicationList
      title="Preprints"
      id="preprints"
      publications={preprints}
    />
    <ServiceSection services={services} />
  </div>
</BaseLayout>
