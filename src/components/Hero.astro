---
import { siteConfig } from "../data/site";
---

<section id="bio" class="scroll-mt-20 animate-on-scroll">
  <div class="flex flex-col-reverse items-center gap-8 md:flex-row md:items-start md:gap-12">
    <!-- Bio text -->
    <div class="flex-1 space-y-4">
      <p class="text-base leading-relaxed text-[var(--color-text)]">
        I am a Ph.D. student under the supervision of <a
          href={siteConfig.author.supervisor.url}
          target="_blank"
          rel="noopener"
          class="font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]"
          >{siteConfig.author.supervisor.name}</a
        >. I'm also a member of the <a
          href={siteConfig.author.lab.url}
          target="_blank"
          rel="noopener"
          class="font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]"
          >{siteConfig.author.lab.name}</a
        > lab at the <a
          href={siteConfig.author.organization.url}
          target="_blank"
          rel="noopener"
          class="font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]"
          >{siteConfig.author.organization.name}</a
        >. I hold a Masters degree in Computer Science from the University of
        Waterloo and a Bachelor of Science in Computer Engineering and
        Mathematics from <a
          href="https://www.aucegypt.edu"
          target="_blank"
          rel="noopener"
          class="font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]"
          >The American University in Cairo</a
        >.
      </p>
      <p class="text-base leading-relaxed text-[var(--color-text)]">
        My research addresses privacy and traceability in machine learning.
        I design efficient privacy-preserving protocols that enable collaborative
        analytics and secure inference without exposing sensitive data, using
        secure multi-party computation and differential privacy. I also develop
        robust watermarking for AI-generated content, exposing vulnerabilities in
        existing schemes through adaptive attacks and building defenses that
        withstand adversarial removal.
      </p>
      <div class="flex flex-wrap gap-2">
        {Object.entries(siteConfig.topics).map(([name, { color }]) => (
          <span
            class="rounded-full border px-3 py-1 text-xs font-medium"
            style={`color: ${color}; border-color: color-mix(in srgb, ${color} 30%, transparent); background-color: color-mix(in srgb, ${color} 8%, transparent);`}
          >
            {name}
          </span>
        ))}
      </div>
      <a
        href="/resume.pdf"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-accent)]/30 px-4 py-2 text-sm font-medium text-[var(--color-accent)] transition-colors hover:bg-[var(--color-accent)]/10 w-fit"
      >
        <svg
          class="w-4 h-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
          <polyline points="10 9 9 9 8 9"></polyline>
        </svg>
        Resume
      </a>
    </div>

    <!-- Avatar -->
    <div class="shrink-0">
      <div
        class="avatar-glow h-40 w-40 overflow-hidden rounded-full ring-2 ring-[var(--color-accent)]/30 ring-offset-2 ring-offset-[var(--color-bg)] md:h-48 md:w-48"
        style="box-shadow: 0 0 20px color-mix(in srgb, var(--color-accent) 30%, transparent), 0 0 40px color-mix(in srgb, var(--color-accent) 15%, transparent);"
      >
        <img
          src={siteConfig.image}
          alt={siteConfig.author.name}
          width="192"
          height="192"
          class="h-full w-full object-cover"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
