---
---

<section id="resume" class="scroll-mt-20">
  <h2
    class="mb-6 text-2xl font-bold text-[var(--color-text)] flex items-center gap-3"
  >
    <span class="h-px flex-1 max-w-8 bg-[var(--color-accent)]"></span>
    Resume
  </h2>

  <div
    class="overflow-hidden rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)]"
  >
    <div class="flex gap-3 p-4">
      <a
        href="/resume.pdf"
        download
        class="inline-flex flex-1 items-center justify-center gap-2 rounded-lg border border-[var(--color-accent)]/30 px-4 py-2.5 text-sm font-medium text-[var(--color-accent)] transition-colors hover:bg-[var(--color-accent)]/10"
      >
        <svg
          class="w-4 h-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Download
      </a>
      <a
        href="/resume.pdf"
        target="_blank"
        rel="noopener"
        class="inline-flex flex-1 items-center justify-center gap-2 rounded-lg border border-[var(--color-border)] px-4 py-2.5 text-sm font-medium text-[var(--color-text-secondary)] transition-colors hover:border-[var(--color-accent)]/30 hover:text-[var(--color-accent)]"
      >
        <svg
          class="w-4 h-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
        View
      </a>
    </div>
  </div>
</section>
