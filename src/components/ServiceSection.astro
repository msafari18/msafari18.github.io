---
interface Service {
  role: string;
  venue: string;
  year: number;
}

interface Props {
  services: Service[];
}

const { services } = Astro.props;
---

<section id="service" class="scroll-mt-20">
  <h2
    class="mb-6 text-2xl font-bold text-[var(--color-text)] flex items-center gap-3 animate-on-scroll"
  >
    <span class="h-px w-4 bg-[var(--color-accent)]"></span>
    Academic Service
  </h2>
  <div class="flex flex-col gap-3">
    {services.map((s, i) => (
      <div
        class="animate-on-scroll group flex items-baseline justify-between gap-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-5 py-4 transition-colors duration-200"
        style={`transition-delay: ${i * 0.1}s`}
      >
        <div class="min-w-0">
          <h3 class="text-base font-semibold text-[var(--color-text)]">
            {s.role}
          </h3>
          <p class="mt-1 text-sm text-[var(--color-text-secondary)]">
            {s.venue}
          </p>
        </div>
        <span class="shrink-0 text-sm font-medium text-[var(--color-text-secondary)]">
          {s.year}
        </span>
      </div>
    ))}
  </div>
</section>
