---
const hobbies = [
  {
    name: "Biking",
    color: "var(--color-accent)",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8">
      <circle cx="5.5" cy="17.5" r="3.5"/>
      <circle cx="18.5" cy="17.5" r="3.5"/>
      <path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
      <path d="M12 17.5L9 9l-3 3h4"/>
      <path d="M9 9l6-3 1.5 5.5"/>
      <path d="M18.5 17.5L15 11.5"/>
    </svg>`
  },
  {
    name: "Travelling",
    color: "var(--color-topic-privacy)",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8">
      <circle cx="12" cy="12" r="10"/>
      <line x1="2" y1="12" x2="22" y2="12"/>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
    </svg>`
  },
  {
    name: "Reading",
    color: "var(--color-topic-watermark)",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8">
      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
      <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
      <line x1="9" y1="7" x2="15" y2="7"/>
      <line x1="9" y1="11" x2="13" y2="11"/>
    </svg>`
  },
];
---

<section id="hobbies" class="scroll-mt-20">
  <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)] flex items-center gap-3">
    <span class="h-px w-4 bg-[var(--color-accent)]"></span>
    How I Enjoy Life
  </h2>
  <div class="flex gap-4">
    {hobbies.map((hobby) => (
      <div
        class="group flex flex-1 flex-col items-center gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] py-8 px-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
        style={`hover-border-color: color-mix(in srgb, ${hobby.color} 40%, transparent);`}
      >
        <div
          class="flex h-16 w-16 items-center justify-center rounded-2xl transition-transform duration-300 group-hover:scale-110"
          style={`color: ${hobby.color}; background-color: color-mix(in srgb, ${hobby.color} 15%, transparent);`}
          set:html={hobby.icon}
        />
        <span
          class="text-sm font-semibold tracking-wide"
          style={`color: ${hobby.color};`}
        >
          {hobby.name}
        </span>
      </div>
    ))}
  </div>
</section>