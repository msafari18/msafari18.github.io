---
import ThemeToggle from "./ThemeToggle.astro";
import { siteConfig } from "../data/site";
---

<style is:global>
  header a, header a:hover { color: inherit; }
</style>

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/80 backdrop-blur-lg transition-colors duration-200 text-[var(--color-text)]">
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-3 sm:px-6">
    <a href="/" class="flex items-center gap-2 text-base sm:text-lg font-semibold text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors min-w-0">
      <img src="/favicon.png" alt="" class="h-7 w-7 rounded-full shrink-0" />
      <span class="hidden sm:inline">{siteConfig.title}</span>
      <span class="sm:hidden">{siteConfig.shortTitle}</span>
    </a>

    <nav class="flex items-center gap-1 justify-end">
      <a href="/#bio" data-section="bio" class="nav-link hidden md:block rounded-md px-3 py-2 text-sm text-[var(--color-text)] hover:bg-[var(--color-surface-hover)] transition-colors">Bio</a>
      <a href="/#publications" data-section="publications" class="nav-link hidden md:block rounded-md px-3 py-2 text-sm text-[var(--color-text)] hover:bg-[var(--color-surface-hover)] transition-colors">Publications</a>
      <a href="/#awards" data-section="awards" class="nav-link hidden md:block rounded-md px-3 py-2 text-sm text-[var(--color-text)] hover:bg-[var(--color-surface-hover)] transition-colors">Awards</a>
      <a href="/#presentations" data-section="presentations" class="nav-link hidden md:block rounded-md px-3 py-2 text-sm text-[var(--color-text)] hover:bg-[var(--color-surface-hover)] transition-colors">Presentations</a>
      <a href="/#hobbies" data-section="hobbies" class="nav-link hidden md:block rounded-md px-3 py-2 text-sm text-[var(--color-text)] hover:bg-[var(--color-surface-hover)] transition-colors">Hobbies</a>

      <div class="mx-2 h-5 w-px bg-[var(--color-border)] hidden md:block"></div>

      <a href={`https://github.com/${siteConfig.social.github}`} target="_blank" rel="noopener" class="flex h-9 w-9 items-center justify-center rounded-full text-[var(--color-text)] hover:bg-[var(--color-surface-hover)] transition-colors" aria-label="GitHub">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path></svg>
      </a>
      <a href={`https://linkedin.com/in/${siteConfig.social.linkedin}`} target="_blank" rel="noopener" class="flex h-9 w-9 items-center justify-center rounded-full text-[var(--color-text)] hover:bg-[var(--color-surface-hover)] transition-colors" aria-label="LinkedIn">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
      </a>
      <a href={siteConfig.social.scholar} target="_blank" rel="noopener" class="flex h-9 w-9 items-center justify-center rounded-full text-[var(--color-text)] hover:bg-[var(--color-surface-hover)] transition-colors" aria-label="Google Scholar">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"></path></svg>
      </a>
      <a href={`mailto:${siteConfig.email}`} class="flex h-9 w-9 items-center justify-center rounded-full text-[var(--color-text)] hover:bg-[var(--color-surface-hover)] transition-colors" aria-label="Email">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
      </a>

      <ThemeToggle />
    </nav>
  </div>
</header>

<script>
  function initActiveNav() {
    const navLinks = document.querySelectorAll(".nav-link") as NodeListOf<HTMLAnchorElement>;
    const sectionIds = Array.from(navLinks).map((link) => link.dataset.section).filter(Boolean);
    const sections = sectionIds.map((id) => document.getElementById(id!)).filter(Boolean) as HTMLElement[];
    if (sections.length === 0) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const link = document.querySelector(`.nav-link[data-section="${entry.target.id}"]`);
          if (!link) return;
          if (entry.isIntersecting) {
            navLinks.forEach((l) => l.classList.remove("border-b-2", "border-[var(--color-accent)]"));
            link.classList.add("border-b-2", "border-[var(--color-accent)]");
          }
        });
      },
      { rootMargin: "-50% 0px -50% 0px" },
    );
    sections.forEach((section) => observer.observe(section));
  }
  initActiveNav();
  document.addEventListener("astro:after-swap", initActiveNav);
</script>
