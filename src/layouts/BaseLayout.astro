---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import SEOHead from "../components/SEOHead.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath } = Astro.props;

const pageTitle = title ? `${title} | Abdulrahman Diaa` : "Abdulrahman Diaa";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Anti-FOUC: set theme before any render -->
    <script is:inline>
      if (localStorage.getItem("theme") === "light") {
        document.documentElement.classList.add("light");
      }
    </script>

    <title>{pageTitle}</title>
    <link rel="icon" type="image/jpeg" href="/favicon.jpeg" />

    <!-- Font preconnects -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Preload critical image -->
    <link rel="preload" href="/images/bio-photo.jpeg" as="image" />

    <SEOHead title={title} description={description} canonicalPath={canonicalPath} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <ScrollToTop />
  </body>
</html>
