---
import { ViewTransitions } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import SEOHead from "../components/SEOHead.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEOHead title={title} description={description} image={image} />
    <ViewTransitions />
  </head>
  <body>
    <div class="flower-bg" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" class="flower-svg">

        <!-- TOP LEFT CLUSTER -->
        <g transform="translate(55, 70) rotate(15)" opacity="0.30">
          <circle cx="0" cy="-20" r="10" fill="var(--flower-pink)"/>
          <circle cx="19" cy="-6" r="10" fill="var(--flower-pink)"/>
          <circle cx="12" cy="16" r="10" fill="var(--flower-pink)"/>
          <circle cx="-12" cy="16" r="10" fill="var(--flower-pink)"/>
          <circle cx="-19" cy="-6" r="10" fill="var(--flower-pink)"/>
          <circle cx="0" cy="0" r="8" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(130, 38) rotate(-10)" opacity="0.28">
          <circle cx="0" cy="-12" r="6" fill="var(--flower-lavender)"/>
          <circle cx="11" cy="-4" r="6" fill="var(--flower-lavender)"/>
          <circle cx="7" cy="10" r="6" fill="var(--flower-lavender)"/>
          <circle cx="-7" cy="10" r="6" fill="var(--flower-lavender)"/>
          <circle cx="-11" cy="-4" r="6" fill="var(--flower-lavender)"/>
          <circle cx="0" cy="0" r="5" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(190, 95) rotate(25)" opacity="0.26">
          <circle cx="0" cy="-9" r="5" fill="var(--flower-teal)"/>
          <circle cx="9" cy="-3" r="5" fill="var(--flower-teal)"/>
          <circle cx="6" cy="8" r="5" fill="var(--flower-teal)"/>
          <circle cx="-6" cy="8" r="5" fill="var(--flower-teal)"/>
          <circle cx="-9" cy="-3" r="5" fill="var(--flower-teal)"/>
          <circle cx="0" cy="0" r="4" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(28, 158) rotate(-5)" opacity="0.26">
          <circle cx="0" cy="-15" r="8" fill="var(--flower-mint)"/>
          <circle cx="14" cy="-5" r="8" fill="var(--flower-mint)"/>
          <circle cx="9" cy="12" r="8" fill="var(--flower-mint)"/>
          <circle cx="-9" cy="12" r="8" fill="var(--flower-mint)"/>
          <circle cx="-14" cy="-5" r="8" fill="var(--flower-mint)"/>
          <circle cx="0" cy="0" r="6" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(230, 55) rotate(40)" opacity="0.24">
          <circle cx="0" cy="-8" r="4" fill="var(--flower-pink)"/>
          <circle cx="8" cy="-3" r="4" fill="var(--flower-pink)"/>
          <circle cx="5" cy="7" r="4" fill="var(--flower-pink)"/>
          <circle cx="-5" cy="7" r="4" fill="var(--flower-pink)"/>
          <circle cx="-8" cy="-3" r="4" fill="var(--flower-pink)"/>
          <circle cx="0" cy="0" r="3" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(160, 170) rotate(-30)" opacity="0.24">
          <circle cx="0" cy="-10" r="5" fill="var(--flower-lavender)"/>
          <circle cx="9" cy="-3" r="5" fill="var(--flower-lavender)"/>
          <circle cx="6" cy="8" r="5" fill="var(--flower-lavender)"/>
          <circle cx="-6" cy="8" r="5" fill="var(--flower-lavender)"/>
          <circle cx="-9" cy="-3" r="5" fill="var(--flower-lavender)"/>
          <circle cx="0" cy="0" r="4" fill="var(--flower-yellow)"/>
        </g>
        <ellipse cx="100" cy="128" rx="5" ry="13" fill="var(--flower-mint)" opacity="0.26" transform="rotate(25, 100, 128)"/>
        <ellipse cx="158" cy="52" rx="4" ry="10" fill="var(--flower-mint)" opacity="0.24" transform="rotate(-15, 158, 52)"/>
        <ellipse cx="210" cy="140" rx="4" ry="11" fill="var(--flower-teal)" opacity="0.22" transform="rotate(40, 210, 140)"/>
        <ellipse cx="70" cy="200" rx="4" ry="10" fill="var(--flower-mint)" opacity="0.21" transform="rotate(-10, 70, 200)"/>

        <!-- TOP RIGHT CLUSTER -->
        <g transform="translate(1380, 65) rotate(-15)" opacity="0.30">
          <circle cx="0" cy="-20" r="10" fill="var(--flower-lavender)"/>
          <circle cx="19" cy="-6" r="10" fill="var(--flower-lavender)"/>
          <circle cx="12" cy="16" r="10" fill="var(--flower-lavender)"/>
          <circle cx="-12" cy="16" r="10" fill="var(--flower-lavender)"/>
          <circle cx="-19" cy="-6" r="10" fill="var(--flower-lavender)"/>
          <circle cx="0" cy="0" r="8" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(1308, 38) rotate(10)" opacity="0.28">
          <circle cx="0" cy="-14" r="7" fill="var(--flower-pink)"/>
          <circle cx="13" cy="-4" r="7" fill="var(--flower-pink)"/>
          <circle cx="8" cy="11" r="7" fill="var(--flower-pink)"/>
          <circle cx="-8" cy="11" r="7" fill="var(--flower-pink)"/>
          <circle cx="-13" cy="-4" r="7" fill="var(--flower-pink)"/>
          <circle cx="0" cy="0" r="6" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(1248, 88) rotate(-25)" opacity="0.26">
          <circle cx="0" cy="-9" r="5" fill="var(--flower-mint)"/>
          <circle cx="9" cy="-3" r="5" fill="var(--flower-mint)"/>
          <circle cx="6" cy="8" r="5" fill="var(--flower-mint)"/>
          <circle cx="-6" cy="8" r="5" fill="var(--flower-mint)"/>
          <circle cx="-9" cy="-3" r="5" fill="var(--flower-mint)"/>
          <circle cx="0" cy="0" r="4" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(1422, 158) rotate(8)" opacity="0.26">
          <circle cx="0" cy="-15" r="8" fill="var(--flower-teal)"/>
          <circle cx="14" cy="-5" r="8" fill="var(--flower-teal)"/>
          <circle cx="9" cy="12" r="8" fill="var(--flower-teal)"/>
          <circle cx="-9" cy="12" r="8" fill="var(--flower-teal)"/>
          <circle cx="-14" cy="-5" r="8" fill="var(--flower-teal)"/>
          <circle cx="0" cy="0" r="6" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(1210, 45) rotate(35)" opacity="0.24">
          <circle cx="0" cy="-8" r="4" fill="var(--flower-teal)"/>
          <circle cx="8" cy="-3" r="4" fill="var(--flower-teal)"/>
          <circle cx="5" cy="7" r="4" fill="var(--flower-teal)"/>
          <circle cx="-5" cy="7" r="4" fill="var(--flower-teal)"/>
          <circle cx="-8" cy="-3" r="4" fill="var(--flower-teal)"/>
          <circle cx="0" cy="0" r="3" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(1270, 175) rotate(-20)" opacity="0.24">
          <circle cx="0" cy="-10" r="5" fill="var(--flower-pink)"/>
          <circle cx="9" cy="-3" r="5" fill="var(--flower-pink)"/>
          <circle cx="6" cy="8" r="5" fill="var(--flower-pink)"/>
          <circle cx="-6" cy="8" r="5" fill="var(--flower-pink)"/>
          <circle cx="-9" cy="-3" r="5" fill="var(--flower-pink)"/>
          <circle cx="0" cy="0" r="4" fill="var(--flower-yellow)"/>
        </g>
        <ellipse cx="1338" cy="118" rx="5" ry="13" fill="var(--flower-mint)" opacity="0.26" transform="rotate(-30, 1338, 118)"/>
        <ellipse cx="1278" cy="48" rx="4" ry="10" fill="var(--flower-lavender)" opacity="0.24" transform="rotate(20, 1278, 48)"/>
        <ellipse cx="1230" cy="138" rx="4" ry="11" fill="var(--flower-teal)" opacity="0.22" transform="rotate(-40, 1230, 138)"/>
        <ellipse cx="1370" cy="205" rx="4" ry="10" fill="var(--flower-mint)" opacity="0.21" transform="rotate(15, 1370, 205)"/>

        <!-- TOP CENTER -->
        <g transform="translate(620, 28) rotate(5)" opacity="0.22">
          <circle cx="0" cy="-9" r="5" fill="var(--flower-pink)"/>
          <circle cx="9" cy="-3" r="5" fill="var(--flower-pink)"/>
          <circle cx="6" cy="8" r="5" fill="var(--flower-pink)"/>
          <circle cx="-6" cy="8" r="5" fill="var(--flower-pink)"/>
          <circle cx="-9" cy="-3" r="5" fill="var(--flower-pink)"/>
          <circle cx="0" cy="0" r="4" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(780, 45) rotate(-18)" opacity="0.20">
          <circle cx="0" cy="-8" r="4" fill="var(--flower-lavender)"/>
          <circle cx="8" cy="-3" r="4" fill="var(--flower-lavender)"/>
          <circle cx="5" cy="7" r="4" fill="var(--flower-lavender)"/>
          <circle cx="-5" cy="7" r="4" fill="var(--flower-lavender)"/>
          <circle cx="-8" cy="-3" r="4" fill="var(--flower-lavender)"/>
          <circle cx="0" cy="0" r="3" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(950, 22) rotate(30)" opacity="0.19">
          <circle cx="0" cy="-7" r="4" fill="var(--flower-teal)"/>
          <circle cx="7" cy="-2" r="4" fill="var(--flower-teal)"/>
          <circle cx="4" cy="6" r="4" fill="var(--flower-teal)"/>
          <circle cx="-4" cy="6" r="4" fill="var(--flower-teal)"/>
          <circle cx="-7" cy="-2" r="4" fill="var(--flower-teal)"/>
          <circle cx="0" cy="0" r="3" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(1080, 55) rotate(-8)" opacity="0.20">
          <circle cx="0" cy="-9" r="5" fill="var(--flower-mint)"/>
          <circle cx="9" cy="-3" r="5" fill="var(--flower-mint)"/>
          <circle cx="6" cy="8" r="5" fill="var(--flower-mint)"/>
          <circle cx="-6" cy="8" r="5" fill="var(--flower-mint)"/>
          <circle cx="-9" cy="-3" r="5" fill="var(--flower-mint)"/>
          <circle cx="0" cy="0" r="4" fill="var(--flower-yellow)"/>
        </g>
        <ellipse cx="700" cy="55" rx="4" ry="9" fill="var(--flower-mint)" opacity="0.20" transform="rotate(20, 700, 55)"/>
        <ellipse cx="870" cy="35" rx="3" ry="8" fill="var(--flower-lavender)" opacity="0.19" transform="rotate(-25, 870, 35)"/>
        <ellipse cx="1020" cy="48" rx="4" ry="9" fill="var(--flower-teal)" opacity="0.19" transform="rotate(35, 1020, 48)"/>

        <!-- MID LEFT -->
        <g transform="translate(22, 320) rotate(12)" opacity="0.20">
          <circle cx="0" cy="-12" r="6" fill="var(--flower-pink)"/>
          <circle cx="11" cy="-4" r="6" fill="var(--flower-pink)"/>
          <circle cx="7" cy="10" r="6" fill="var(--flower-pink)"/>
          <circle cx="-7" cy="10" r="6" fill="var(--flower-pink)"/>
          <circle cx="-11" cy="-4" r="6" fill="var(--flower-pink)"/>
          <circle cx="0" cy="0" r="5" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(18, 480) rotate(-8)" opacity="0.19">
          <circle cx="0" cy="-14" r="7" fill="var(--flower-mint)"/>
          <circle cx="13" cy="-4" r="7" fill="var(--flower-mint)"/>
          <circle cx="8" cy="11" r="7" fill="var(--flower-mint)"/>
          <circle cx="-8" cy="11" r="7" fill="var(--flower-mint)"/>
          <circle cx="-13" cy="-4" r="7" fill="var(--flower-mint)"/>
          <circle cx="0" cy="0" r="6" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(35, 640) rotate(20)" opacity="0.18">
          <circle cx="0" cy="-9" r="5" fill="var(--flower-lavender)"/>
          <circle cx="9" cy="-3" r="5" fill="var(--flower-lavender)"/>
          <circle cx="6" cy="8" r="5" fill="var(--flower-lavender)"/>
          <circle cx="-6" cy="8" r="5" fill="var(--flower-lavender)"/>
          <circle cx="-9" cy="-3" r="5" fill="var(--flower-lavender)"/>
          <circle cx="0" cy="0" r="4" fill="var(--flower-yellow)"/>
        </g>
        <ellipse cx="50" cy="400" rx="4" ry="11" fill="var(--flower-mint)" opacity="0.19" transform="rotate(15, 50, 400)"/>
        <ellipse cx="42" cy="560" rx="4" ry="10" fill="var(--flower-teal)" opacity="0.18" transform="rotate(-20, 42, 560)"/>

        <!-- MID RIGHT -->
        <g transform="translate(1430, 320) rotate(-12)" opacity="0.20">
          <circle cx="0" cy="-12" r="6" fill="var(--flower-teal)"/>
          <circle cx="11" cy="-4" r="6" fill="var(--flower-teal)"/>
          <circle cx="7" cy="10" r="6" fill="var(--flower-teal)"/>
          <circle cx="-7" cy="10" r="6" fill="var(--flower-teal)"/>
          <circle cx="-11" cy="-4" r="6" fill="var(--flower-teal)"/>
          <circle cx="0" cy="0" r="5" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(1438, 480) rotate(8)" opacity="0.19">
          <circle cx="0" cy="-10" r="5" fill="var(--flower-pink)"/>
          <circle cx="9" cy="-3" r="5" fill="var(--flower-pink)"/>
          <circle cx="6" cy="8" r="5" fill="var(--flower-pink)"/>
          <circle cx="-6" cy="8" r="5" fill="var(--flower-pink)"/>
          <circle cx="-9" cy="-3" r="5" fill="var(--flower-pink)"/>
          <circle cx="0" cy="0" r="4" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(1425, 640) rotate(-18)" opacity="0.18">
          <circle cx="0" cy="-14" r="7" fill="var(--flower-lavender)"/>
          <circle cx="13" cy="-4" r="7" fill="var(--flower-lavender)"/>
          <circle cx="8" cy="11" r="7" fill="var(--flower-lavender)"/>
          <circle cx="-8" cy="11" r="7" fill="var(--flower-lavender)"/>
          <circle cx="-13" cy="-4" r="7" fill="var(--flower-lavender)"/>
          <circle cx="0" cy="0" r="6" fill="var(--flower-yellow)"/>
        </g>
        <ellipse cx="1400" cy="400" rx="4" ry="11" fill="var(--flower-lavender)" opacity="0.19" transform="rotate(-15, 1400, 400)"/>
        <ellipse cx="1410" cy="560" rx="4" ry="10" fill="var(--flower-mint)" opacity="0.18" transform="rotate(22, 1410, 560)"/>

        <!-- BOTTOM -->
        <g transform="translate(80, 850) rotate(-10)" opacity="0.20">
          <circle cx="0" cy="-15" r="8" fill="var(--flower-pink)"/>
          <circle cx="14" cy="-5" r="8" fill="var(--flower-pink)"/>
          <circle cx="9" cy="12" r="8" fill="var(--flower-pink)"/>
          <circle cx="-9" cy="12" r="8" fill="var(--flower-pink)"/>
          <circle cx="-14" cy="-5" r="8" fill="var(--flower-pink)"/>
          <circle cx="0" cy="0" r="6" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(200, 880) rotate(15)" opacity="0.18">
          <circle cx="0" cy="-9" r="5" fill="var(--flower-teal)"/>
          <circle cx="9" cy="-3" r="5" fill="var(--flower-teal)"/>
          <circle cx="6" cy="8" r="5" fill="var(--flower-teal)"/>
          <circle cx="-6" cy="8" r="5" fill="var(--flower-teal)"/>
          <circle cx="-9" cy="-3" r="5" fill="var(--flower-teal)"/>
          <circle cx="0" cy="0" r="4" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(1360, 860) rotate(20)" opacity="0.20">
          <circle cx="0" cy="-15" r="8" fill="var(--flower-lavender)"/>
          <circle cx="14" cy="-5" r="8" fill="var(--flower-lavender)"/>
          <circle cx="9" cy="12" r="8" fill="var(--flower-lavender)"/>
          <circle cx="-9" cy="12" r="8" fill="var(--flower-lavender)"/>
          <circle cx="-14" cy="-5" r="8" fill="var(--flower-lavender)"/>
          <circle cx="0" cy="0" r="6" fill="var(--flower-yellow)"/>
        </g>
        <g transform="translate(1240, 840) rotate(-15)" opacity="0.18">
          <circle cx="0" cy="-10" r="5" fill="var(--flower-mint)"/>
          <circle cx="9" cy="-3" r="5" fill="var(--flower-mint)"/>
          <circle cx="6" cy="8" r="5" fill="var(--flower-mint)"/>
          <circle cx="-6" cy="8" r="5" fill="var(--flower-mint)"/>
          <circle cx="-9" cy="-3" r="5" fill="var(--flower-mint)"/>
          <circle cx="0" cy="0" r="4" fill="var(--flower-yellow)"/>
        </g>
        <ellipse cx="150" cy="860" rx="4" ry="10" fill="var(--flower-mint)" opacity="0.19" transform="rotate(30, 150, 860)"/>
        <ellipse cx="1300" cy="870" rx="4" ry="10" fill="var(--flower-lavender)" opacity="0.19" transform="rotate(-25, 1300, 870)"/>

      </svg>
    </div>

    <Header />
    <main class="relative z-10">
      <slot />
    </main>
    <Footer />
    <ScrollToTop />
  </body>
</html>

<style is:global>
  :root {
    --flower-pink: #F4A7B4;
    --flower-lavender: #A98BD6;
    --flower-mint: #7CC89A;
    --flower-yellow: #F2C94C;
    --flower-teal: #5BB8C4;
  }

  .flower-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .flower-svg {
    width: 100%;
    height: 100%;
  }

  main {
    position: relative;
    z-index: 10;
  }
</style>